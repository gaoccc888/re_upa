vcftools --vcf /home/gao/workspace/treemix/312_filtered.recode.LD.pruned.recode.vcf --plink-tped --out 312samples

# 1.2 文件修改
# 312samples.tfam文件修改第一列数据为群体名称

# 1.3 提取文件sample.pop.cov，格式为：共三列，前两列与修改后的sample.tfam前两列一样，为群体ID和样本ID，第三列和第一列一致，tab分隔。
cat 208samples.tfam | awk '{print $1"\t"$2"\t"$1}' > 208samples.pop.cov

